{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/Backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/Frontend/index.html"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "entrypoint": "Frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "Backend",
      "routePrefix": "/_/backend"
    }
  }
}
